# Server
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000

# Auth
JWT_SECRET=super-secret-change-me
JWT_EXPIRES_IN=7d

# AI Provider (optional - falls back to heuristic engine if not set)
# Supported: openai, gemini (configured automatically if GEMINI_API_KEY is present)
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# CSV processing
AI_BATCH_SIZE=20
AI_MAX_RETRIES=3
AI_CONCURRENCY=3
